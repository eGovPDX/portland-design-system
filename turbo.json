{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "storybook:build": {
      "dependsOn": ["^storybook:build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
