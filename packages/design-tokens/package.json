{
  "name": "@cityofportland/design-tokens",
  "version": "2.0.0-alpha.0",
  "description": "Design tokens managed in Style Dictionary for the Portland Design System.",
  "author": {
    "name": "City of Portland, Oregon"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/js/base.js",
    "./*": "./dist/*.js",
    "./css/*": "./dist/css/*",
    "./js/*": "./dist/js/*",
    "./json/*": "./dist/json/*",
    "./scss/*": "./dist/scss/*",
    "./tailwind/*": "./dist/tailwind/*"
  },
  "scripts": {
    "prebuild": "tsup",
    "build": "node dist/cli/build.js --mode production",
    "build:dev": "node dist/cli/build.js --mode development",
    "clean": "rm -rf dist/",
    "dev": "node dist/cli/watch.js --mode development",
    "storybook": "storybook dev -p 6007 --no-open",
    "storybook:build": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.4.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eGovPDX/portland-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/eGovPDX/portland-design-system/issues"
  },
  "homepage": "https://github.com/eGovPDX/portland-design-system#readme"
}
