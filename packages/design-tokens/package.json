{
  "name": "@cityofportland/design-tokens",
  "version": "1.0.0-alpha.0",
  "description": "Design tokens managed in Style Dictionary for the Portland Design System.",
  "author": {
    "name": "City of Portland, Oregon"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/base.js",
    "./css/*": "./dist/css/*",
    "./js/*": "./dist/js/*",
    "./scss/*": "./dist/scss/*",
    "./tailwind/*": "./dist/tailwind/*",
    "./unocss/*": "./dist/unocss/*"
  },
  "scripts": {
    "prebuild": "tsup",
    "build": "node dist/build.js",
    "clean": "rm -rf dist/",
    "dev": "pnpm prebuild && node dist/watch.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "style-dictionary": "^5.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eGovPDX/portland-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/eGovPDX/portland-design-system/issues"
  },
  "homepage": "https://github.com/eGovPDX/portland-design-system#readme"
}
