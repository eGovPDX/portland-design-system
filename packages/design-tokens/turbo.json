{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "dependsOn": ["prebuild"],
      "persistent": true,
      "cache": false
    },
    "storybook": {
      "with": ["dev"],
      "persistent": true,
      "cache": false
    },
    "prebuild": {
      "outputs": ["dist/**"]
    }
  }
}
