{
  "name": "@cityofportland/components-css",
  "version": "1.0.0-alpha.0",
  "description": "CSS component styles for the Portland Design System built with Tailwind and PostCSS",
  "author": {
    "name": "City of Portland, Oregon"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/main.css",
    "./*": "./dist/*.css",
    "./*.css": "./dist/*.css"
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:upstream": "pnpm --filter '{.}^...' build",
    "clean": "rm -rf dist",
    "dev": "vite build --watch --mode development", 
    "storybook": "storybook dev -p 6007 --no-open",
    "storybook:build": "storybook build"
  },
  "devDependencies": {
    "@cityofportland/design-tokens": "workspace:*",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.1.16",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.9.3",
    "vite": "^7.1.12"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eGovPDX/portland-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/eGovPDX/portland-design-system/issues"
  },
  "homepage": "https://github.com/eGovPDX/portland-design-system#readme"
}
