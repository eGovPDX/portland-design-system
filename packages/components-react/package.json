{
  "name": "@cityofportland/components-react",
  "version": "1.0.0-alpha.0",
  "description": "Portland Component Library using design tokens from Figma",
  "author": {
    "name": "City of Portland, Oregon"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "import": "./dist/*.es.js",
      "types": "./dist/*.d.ts"
    },
    "./*.css": "./dist/*.css"
  },
  "scripts": {
    "build": "vite build",
    "build:upstream": "pnpm --filter '{.}^...' build",
    "dev": "vite",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "test": "vitest"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@cityofportland/components-css": "workspace:*",
    "@cityofportland/design-tokens": "workspace:*",
    "@cityofportland/types": "workspace:*",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@storybook/addon-a11y": "^10.2.11",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.2.11",
    "@storybook/addon-themes": "^10.2.11",
    "@storybook/addon-vitest": "^10.2.11",
    "@storybook/react-vite": "^10.2.11",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-jest": "^30.2.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.4.1",
    "storybook-addon-pseudo-states": "^10.2.11",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.0.2",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eGovPDX/portland-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/eGovPDX/portland-design-system/issues"
  },
  "homepage": "https://github.com/eGovPDX/portland-design-system#readme"
}
