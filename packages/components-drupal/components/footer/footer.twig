{#
/**
 * @file
 * Template for Portland Footer component.
 *
 * Available variables:
 * - copyrightStart: The starting year for the copyright notice
 * - attributes: Additional HTML attributes
 * - footer_content: Footer content (slot)
 */
#}

{# Set default values #}
{% set attributes = attributes|default(create_attribute()) %}

{# Combine all classes #}
{% set attributes = attributes.addClass('footer') %}

{% embed 'portland:box' with { 
  as: 'footer',
  color,
  variant,
  attributes,
} %}
  {% block box_content %}
    {% block footer_content %}{{ footer_content }}{% endblock %}
    <section class="footer__copyright" aria-labelledby="footer-copyright-heading">
      {% include 'portland:city-seal' with { size: 'sm' } only %}
      <span class="footer__copyright-text" data-copyright-start="{{ copyrightStart }}">
        <h2 id="footer-copyright-heading">City of Portland, Oregon</h2>
      </span>
    </section>
  {% endblock %}
{% endembed %}
