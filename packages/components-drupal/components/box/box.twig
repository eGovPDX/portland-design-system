{#
/**
 * @file
 * Template for Portland Box component.
 *
 * Available variables:
 * - as: HTML element to use (div, section, article, aside, main, header, footer, nav)
 * - color: Box color (default, primary, secondary, success, danger, warning, info, disabled)
 * - variant: Box visual style (subtle, moderate, emphasis, strong)
 * - content: Box content (slot)
 * - attributes: Additional HTML attributes
 */
#}

{% apply spaceless %}

{# Set default values #}
{% set element = as|default('div') %}

{% set classes = ['box'] %}
{% set errors = [] %}

{# Validate color and variant combinations #}
{% if color == "fixed" %}
	{% if variant != "light" and variant != "dark" %}
		{% set errors = errors|merge(['invalid-fixed-variant']) %}
		
		{% set variant = undefined %}
		{% set color = undefined %}
	{% endif %}
{% else %}
	{% if variant == "light" or variant == "dark" %}
		{% set errors = errors|merge(['invalid-color-variant']) %}

		{% set variant = undefined %}
		{% set color = undefined %}
	{% endif %}
{% endif %}

{# Size classes #}
{% if color is defined %}
	{% set color = ["box--" ~ color] %}

	{% set classes = classes|merge(color) %}
{% endif %}

{# Variant classes #}
{% if variant is defined %}
	{% set variant = ["box--" ~ variant] %}

	{% set classes = classes|merge(variant) %}
{% endif %}

<{{element}} {{ attributes.addClass(classes).setAttribute("data-errors", errors) }}>
	{% block box_content %}
		{{ box_content }}
	{% endblock %}
</{{element}}>

{% endapply %}
