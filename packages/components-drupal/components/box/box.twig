{#
/**
 * @file
 * Template for Portland Box component.
 *
 * Available variables:
 * - as: HTML element to use (div, section, article, aside, main, header, footer, nav)
 * - color: Box color (default, primary, secondary, success, danger, warning, info, disabled)
 * - variant: Box visual style (subtle, moderate, emphasis, strong)
 * - box_content: Box content (slot)
 * - attributes: Additional HTML attributes
 */
#}

{% apply spaceless %}

{# Set default values #}
{% set element = as|default('div') %}
{% set attributes = attributes|default(create_attribute()) %}

{% set classes = ['box'] %}

{% if color is defined %}
  {% set attributes = attributes.setAttribute("data-color", color) %}
  {% set classes = classes|merge(["box--" ~ color]) %}
{% endif %}

{% if variant is defined %}
  {% set attributes = attributes.setAttribute("data-variant", variant) %}
  {% set classes = classes|merge(["box--" ~ variant]) %}
{% endif %}

<{{element}} {{ attributes.addClass(classes) }}>
  {% block box_content %}
    {{ box_content }}
  {% endblock %}
</{{element}}>

{% endapply %}
