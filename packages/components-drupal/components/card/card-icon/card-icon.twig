<div class="card__media card__media--inset{% if position == 'left' %} card__media--left{% endif %}{% if position == 'right' %} card__media--right{% endif %}">
	<div class="card__icon" role="img" aria-label="{{ label|default('Card Icon') }}">
		{% block icon %}
			{{ icon }}
		{% endblock %}
	</div>
</div>
